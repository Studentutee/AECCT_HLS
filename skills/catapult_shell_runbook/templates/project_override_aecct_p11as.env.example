# AECCT P11AS example override
MODE="run-only"
REPO_ROOT="/abs/path/to/AECCT_HLS"
PROJECT_NAME="p11as_corrected_chain"
PROJECT_TCL="${REPO_ROOT}/scripts/catapult/p11as_corrected_chain_project.tcl"
PROJECT_ENTRY_DESC="corrected-chain compile-first project tcl"
TOP_TARGET="aecct::TopManagedAttentionChainCatapultTop"
ENTRY_TU="src/catapult/p11as_top_managed_attention_chain_entry.cpp"
CATAPULT_BIN="/cad/mentor/Catapult/2025.3/Mgc_home/bin/catapult"
ALLOW_PATH_CATAPULT=0
RUN_TAG="${PROJECT_NAME}_$(date +%Y%m%d_%H%M%S)"
CATAPULT_OUTDIR="${REPO_ROOT}/build/catapult/${RUN_TAG}"
REMOTE_HOST="<catapult_server>"
REMOTE_USER="<username>"
REMOTE_REPO_ROOT="${REPO_ROOT}"
MESSAGE_SEARCH_ROOTS=("${REPO_ROOT}/build")
BLOCKER_KEYWORDS=("# Error" "Compilation aborted" "HIER-" "CIN-249")
WARNING_KEYWORDS=("Warning" "CIN-63" "CRD-549" "CIN-18")
GOVERNANCE_POSTURE_DEFAULT=("not Catapult closure" "not SCVerify closure")
