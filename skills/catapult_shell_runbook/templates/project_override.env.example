# project_override.env.example
#
# 請用 Bash source 方式載入：
#   source ./project_override.env
#
# 這份檔案描述「本輪要跑什麼」，由 Catapult Shell Runbook 讀取。
# 它不負責 SSH 登入；請先用可用的 SSH 公鑰登入遠端 Linux 主機後，再執行 runbook。
# 可使用 ssh-ed25519 公鑰。

# --- 執行模式 ---
# run-only      : 只執行與蒐證，不修改檔案
# patch-rerun   : 先做最小修改，再重跑並比對
MODE="run-only"

# --- 專案基礎資訊 ---
REPO_ROOT="/abs/path/to/repo"
PROJECT_NAME="my_project"
PROJECT_TCL="/abs/path/to/repo/scripts/catapult/my_project.tcl"
PROJECT_ENTRY_DESC="compile-first project tcl"
TOP_TARGET="my_namespace::MyTop"
ENTRY_TU="src/catapult/my_top_entry.cpp"

# --- Catapult binary ---
# 預設固定使用 Catapult 2025.3；如站點不同可在專案 override 覆寫。
CATAPULT_BIN="/cad/mentor/Catapult/2025.3/Mgc_home/bin/catapult"

# 若要允許退回 PATH 中的 catapult，設為 1。
# 預設建議維持 0，只使用上面的絕對路徑。
ALLOW_PATH_CATAPULT=0

# --- run tag / outdir ---
# RUN_TAG 可用來區分每次執行。
# 如果你是手動填值，也可以直接寫死，例如：
# RUN_TAG="p11as_20260327_101500"
RUN_TAG="${PROJECT_NAME}_$(date +%Y%m%d_%H%M%S)"
CATAPULT_OUTDIR="${REPO_ROOT}/build/catapult/${RUN_TAG}"

# --- optional remote context ---
# 供外層 wrapper / report 使用；核心 runbook 不負責 SSH 登入。
REMOTE_HOST="hls-server"
REMOTE_USER="your_user"
REMOTE_REPO_ROOT="${REPO_ROOT}"

# --- messages.txt 搜尋根目錄 ---
# Bash array；可留空。runbook 會自動加上 CATAPULT_OUTDIR 與 REPO_ROOT。
MESSAGE_SEARCH_ROOTS=(
  "${REPO_ROOT}/build"
  "${REPO_ROOT}/out"
)

# --- grep 關鍵字 ---
# 這些字串會額外寫到 grep_blockers.txt / grep_warnings.txt。
BLOCKER_KEYWORDS=(
  "# Error"
  "Compilation aborted"
  "license"
  "Segmentation fault"
  "invalid command name"
)

WARNING_KEYWORDS=(
  "Warning"
  "CIN-63"
  "CRD-549"
)

# --- optional notes for report ---
GOVERNANCE_POSTURE_DEFAULT=(
  "not Catapult closure"
  "not SCVerify closure"
)

# --- AECCT 範例（註解掉避免直接生效） ---
