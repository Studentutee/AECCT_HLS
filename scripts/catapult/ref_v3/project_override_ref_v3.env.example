# ref_v3 project override for Catapult Shell Runbook (example)
#
# Usage:
#   source ./project_override_ref_v3.env
#
# This file declares "what to run" for ref_v3.
# Runbook is responsible for execution/evidence collection.

MODE="run-only"

REPO_ROOT="/home/peter/AECCT/AECCT_HLS-master"
PROJECT_NAME="ref_v3"
PROJECT_TCL="${REPO_ROOT}/scripts/catapult/ref_v3/project.tcl"
PROJECT_ENTRY_DESC="ref_v3 compile-entry project tcl"
TOP_TARGET="aecct_ref::ref_v3::RefV3CatapultTop"
ENTRY_TU="AECCT_ac_ref/catapult/ref_v3/ref_v3_catapult_top_entry.cpp"

CATAPULT_BIN="/cad/mentor/Catapult/2025.3/Mgc_home/bin/catapult"
ALLOW_PATH_CATAPULT=0

RUN_TAG="${PROJECT_NAME}_$(date +%Y%m%d_%H%M%S)"
CATAPULT_OUTDIR="${REPO_ROOT}/build/ref_v3/catapult_interactive_compile_check_${RUN_TAG}"

REMOTE_HOST="hls-server"
REMOTE_USER="peter"
REMOTE_REPO_ROOT="${REPO_ROOT}"

MESSAGE_SEARCH_ROOTS=(
  "${REPO_ROOT}/build/ref_v3"
  "${REPO_ROOT}/build"
)

BLOCKER_KEYWORDS=(
  "# Error"
  "Compilation aborted"
  "HIER-"
  "CIN-"
  "LIB-"
  "SCVerify"
  "mc_scverify"
  "license"
  "LIC-"
)

WARNING_KEYWORDS=(
  "Warning"
  "CRD-"
)
