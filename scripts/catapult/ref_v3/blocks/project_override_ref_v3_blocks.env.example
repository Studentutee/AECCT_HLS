# ref_v3 block-level Catapult override (example)
#
# Usage idea:
#   source ./project_override_ref_v3_blocks.env
#
# posture: not Catapult closure
# posture_scverify: not SCVerify closure

MODE="run-only"

REPO_ROOT="/home/peter/AECCT/AECCT_HLS-master"
PROJECT_ENTRY_DESC="ref_v3 block-level Catapult matrix"
BLOCK_KEYS=("preproc" "attn_kv" "attn_qsoftres" "layernorm" "ffn_linear0" "ffn_linear1" "finalA" "finalB")

CATAPULT_BIN="/cad/mentor/Catapult/2025.3/Mgc_home/bin/catapult"
ALLOW_PATH_CATAPULT=0

RUN_TAG="ref_v3_blocks_$(date +%Y%m%d_%H%M%S)"
CATAPULT_OUTROOT="${REPO_ROOT}/build/ref_v3/blocks/${RUN_TAG}"

REMOTE_HOST="140.124.41.193"
REMOTE_PORT="2190"
REMOTE_USER="peter"
REMOTE_REPO_ROOT="${REPO_ROOT}"
REMOTE_SSH_IDENTITY=".codex_ssh/id_codex"
REMOTE_KNOWN_HOSTS=".codex_ssh/known_hosts"
REMOTE_REQUIRE_TTY=1
